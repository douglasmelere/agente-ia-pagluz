# --- Seleção de provedor (chat + transcrição de áudio) ---
# gemini  -> usa GOOGLE_API_KEY (padrão)
# openai  -> usa OPENAI_API_KEY (fallback)
AI_PROVIDER=gemini
# Provedor de transcrição de áudio (opcional — padrão: segue AI_PROVIDER)
# Use AUDIO_PROVIDER=gemini mesmo com AI_PROVIDER=openai para evitar Whisper
# AUDIO_PROVIDER=gemini

# --- Google / Gemini (usado quando AI_PROVIDER=gemini) ---
GOOGLE_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash
GEMINI_AUDIO_MODEL=gemini-2.0-flash

# --- OpenAI (usado quando AI_PROVIDER=openai OU como referência) ---
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
OPENAI_WHISPER_MODEL=whisper-1

# --- uazapiGO ---
UAZAPI_BASE_URL=https://your-uazapi-host.example.com
UAZAPI_INSTANCE_TOKEN=your-instance-token
# Token de validação do webhook (opcional — só funciona se a uazapiGO
# suportar header customizado X-Webhook-Secret)
UAZAPI_WEBHOOK_SECRET=

# --- Debounce ---
# Segundos de espera após a última mensagem antes de processar a fila
DEBOUNCE_SECONDS=5

# --- Persistência da Conversa ---
AGENT_DB_FILE=sessions.db

# --- Painel Admin ---
ADMIN_USER=admin
ADMIN_PASS=change-me
# SQLite com o estado das conversas, triggers e settings do painel
ADMIN_DB_FILE=admin.db

# --- Server ---
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8000
